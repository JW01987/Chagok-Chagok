# ========================
# Backend — Database
# ========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chagok_db
DB_USERNAME=
DB_PASSWORD=

# ========================
# Backend — Redis
# ========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================
# Backend — JWT
# ========================
JWT_SECRET=
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=2592000000

# ========================
# Backend — OAuth2 (카카오)
# ========================
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=

# ========================
# Backend — OAuth2 (Apple)
# ========================
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ========================
# Backend — AWS
# ========================
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
# IAM Role 사용 — Access Key 하드코딩 금지

# ========================
# Backend — FCM
# ========================
FCM_CREDENTIALS_PATH=

# ========================
# Frontend
# ========================
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_ENV=local
